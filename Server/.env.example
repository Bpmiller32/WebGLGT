# ---------------------------------------------------------------------------
# Server environment (Express). Copy this file to `.env` and fill in real values.
# All four vars are required — the server throws on startup if any is missing
# (see src/envConfig.ts).
# ---------------------------------------------------------------------------

# Secret used to sign and verify JWTs (6h expiry). Use a long random string.
JWT_KEY=""

# Google Cloud Vision API key. The server vends this to the browser via
# /getApiKey; the OCR request itself is made client-side.
GOOGLE_VISION_API_KEY=""

# Absolute path to the directory of source images to annotate. `.tif` files are
# converted to PNG on the fly via Sharp when served; exports are also written here.
IMAGES_PATH="/absolute/path/to/images"

# Absolute (or relative) path to the Google Cloud service-account JSON used for
# Firestore admin. Conventionally placed next to package.json.
GOOGLECLOUD_SERVICE_ACCOUNT_KEY_PATH="./googlecloudServiceAccount.json"
