# ---------------------------------------------------------------------------
# Client environment (Vite). Copy this file to `.env` and fill in real values.
# Only vars prefixed with VITE_ are exposed to the browser bundle.
# ---------------------------------------------------------------------------

# Demo mode. When "true", the login screen ignores typed credentials and logs
# in as the `demo` user, which triggers the server-side demo reset. Set to
# "false" for normal multi-user operation.
VITE_ISDEMO="false"

# Firebase web-app config.
# Firebase console → Project settings → General → Your apps → SDK setup & config.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN="your-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-project-id"
VITE_FIREBASE_STORAGE_BUCKET="your-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
VITE_FIREBASE_MEASUREMENT_ID=""

# Base URL of the backend (Express server, served under base path /webglgt).
#   Local dev: http://localhost:3002/webglgt
#   Deployed:  https://webglgt.billmill.dev/webglgt
VITE_NGROK_URL="http://localhost:3002/webglgt"

# Tip: to switch between projects, keep a second copy of the values above and
# comment-toggle between the two blocks (see README → Infrastructure).
